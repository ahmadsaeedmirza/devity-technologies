# EmailJS (https://www.emailjs.com/)
# Create a `.env.local` (ignored by git) and copy these values in.
# Vite only exposes env vars prefixed with VITE_.

VITE_EMAILJS_PUBLIC_KEY=YOUR_PUBLIC_KEY
VITE_EMAILJS_SERVICE_ID=service_ww51z6t
VITE_EMAILJS_TEMPLATE_ID_OWNER=template_88f0mph
VITE_EMAILJS_TEMPLATE_ID_REPLY=template_ur4pdjk

# Optional (recommended for SEO): absolute site URL used for canonical/OG URLs
VITE_SITE_URL=https://your-domain.com
